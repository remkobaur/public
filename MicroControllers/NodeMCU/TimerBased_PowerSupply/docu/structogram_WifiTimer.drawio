        <mxCell id="edge2" edge="1" parent="1" source="setup_detail" target="loop_label">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- loop() main container -->
        <mxCell id="loop_container" value="loop() - Core Event Handler&#10;&#10;Runs every 500ms with 250ms delay&#10;&#10;Event Processing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FF;strokeColor=#0066CC;fontSize=10;fontStyle=1;container=1;spacing=10" vertex="1" parent="1">
          <mxGeometry x="450" y="350" width="500" height="400" as="geometry"/>
        </mxCell>
        
        <!-- Button Check Sub-container -->
        <mxCell id="button_check" value="Button Input Handler&#10;&#10;1. Check if button pressed: isButtonPressed()&#10;2. Toggle relay state: Switch_on() or Switch_off()&#10;3. Log event: Log_write(Status)&#10;4. Reset trigger flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFB84D;fontSize=9;align=left;spacing=3" vertex="1" parent="loop_container">
          <mxGeometry x="10" y="50" width="220" height="90" as="geometry"/>
        </mxCell>
        
        <!-- Schedule Check Sub-container -->
        <mxCell id="schedule_check" value="Timer Schedule Evaluation&#10;&#10;1. Get current time: get_time_mm()&#10;2. Evaluate schedules: check_time()&#10;3. Set trigger if time matches window&#10;4. Store schedule match in act_check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFB84D;fontSize=9;align=left;spacing=3" vertex="1" parent="loop_container">
          <mxGeometry x="10" y="155" width="220" height="90" as="geometry"/>
        </mxCell>
        
        <!-- Timer Engine Sub-container -->
        <mxCell id="timer_engine" value="Timer Engine State Machine&#10;&#10;1. Call my_Timer(t_manual, trigger)&#10;2. Returns: 0=idle, 1=active, 2=finished&#10;3. Switch on return value:&#10;   • Start timer &amp; switch on&#10;   • Maintain ON state&#10;   • Stop timer &amp; switch off&#10;4. Log state change if needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFB84D;fontSize=9;align=left;spacing=3" vertex="1" parent="loop_container">
          <mxGeometry x="250" y="50" width="240" height="115" as="geometry"/>
        </mxCell>
        
        <!-- Safety Check Sub-container -->
        <mxCell id="safety_check" value="Safety &amp; Monitoring&#10;&#10;1. isLevelOk() - Water level check&#10;2. Auto-shutdown if critical&#10;3. LED blink alert on low water&#10;4. is_soil_dry() - Read moisture (A0)&#10;5. Update global soil/water status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFB84D;fontSize=9;align=left;spacing=3" vertex="1" parent="loop_container">
          <mxGeometry x="250" y="180" width="240" height="100" as="geometry"/>
        </mxCell>
        
        <!-- Web Server Sub-container -->
        <mxCell id="web_check" value="Web Server Request Handling&#10;&#10;1. exec_WebServer()&#10;2. Check for HTTP POST requests&#10;3. handleRoot() processes:&#10;   • Timer config updates&#10;   • On/Off commands&#10;   • Manual timer override&#10;4. Send HTML response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#FFB84D;fontSize=9;align=left;spacing=3" vertex="1" parent="loop_container">
