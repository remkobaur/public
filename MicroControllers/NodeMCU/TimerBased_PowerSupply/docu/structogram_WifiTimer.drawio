        <!-- setup() details (container) -->
        <mxCell id="setup_detail" value="Initialize Hardware &amp; Network&#10;&#10;• init_IOs() - Configure pins, read sensors&#10;• init_WiFi() - Connect to network&#10;• time_synch() - NTP time sync&#10;• loadConfig() - Load EEPROM settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0F0;strokeColor=#FFCCCC;fontSize=9;strokeDasharray=3 3;container=1" vertex="1" parent="1">
          <mxGeometry x="550" y="180" width="300" height="100" as="geometry"/>
        </mxCell>
        
        <!-- loop() entry -->
        <mxCell id="loop_label" value="MAIN LOOP (500ms cycle)" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=#FFFFCC;strokeColor=#999999" vertex="1" parent="1">
